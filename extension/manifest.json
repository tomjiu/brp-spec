{
  "manifest_version": 2,
  "name": "BRP Bridge Extension",
  "version": "0.5.1",
  "description": "Browser Runtime Protocol - Firefox Extension for AI agent interaction",
  "permissions": [
    "activeTab",
    "tabs",
    "webNavigation",
    "storage",
    "nativeMessaging",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "dist/handlers.js",
      "dist/background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/itree.js",
        "dist/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/gray-16.png",
      "32": "icons/gray-32.png",
      "48": "icons/gray-48.png"
    },
    "default_title": "BRP Bridge"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "brp-bridge@brp-spec.org",
      "strict_min_version": "109.0"
    }
  }
}
